# ── Schengen Visa Bot — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values

# REQUIRED: Get this from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# How often to scan for appointments (default: 2 minutes)
CHECK_INTERVAL_MINUTES=2

# Optional: your own Telegram chat ID for admin alerts
# Get it by messaging @userinfobot
ADMIN_CHAT_ID=

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
